# Public site (sah_frontend) — copy to ".env" for dev or ".env.production" before "npm run build"
# Backend you deployed:
VITE_API_URL=https://sah.nodeteam.site/api
VITE_API_BASE_URL=https://sah.nodeteam.site

# After you deploy the admin dashboard, set its public origin (no trailing slash).
# Used when a student/admin hits /admin on the public site (redirect to dashboard).
VITE_DASHBOARD_BASE_URL=https://YOUR-DASHBOARD-HOST
